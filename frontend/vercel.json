{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/api/:path*"
    },
    {
      "source": "/Beacon/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/Beacon/:path*"
    },
    {
      "source": "/Risk/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/Risk/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
